#!/bin/bash

# tmux-layout: Create a workspace layout for the current client user
# Usage: tmux-layout [project]
#   project - fuzzy project name (e.g. "cdc" matches "spark-cdc")
#
# The client is derived from $USER (one Linux user per client).
# Projects live under $HOME/ directly. The client profile is at ~/.clientrc.

set -e

CLIENT="$USER"
PROJECT="${1:-}"
CLIENTRC="$HOME/.clientrc"

# Resolve project directory.
# Searches (in order): exact path in $HOME, exact path in $HOME/repos,
# then fuzzy match up to 2 levels deep (covers $HOME/repos/<name>),
# excluding any hidden directory.
resolve_project_dir() {
    local query="$1"

    [ -d "$HOME/$query" ] && echo "$HOME/$query" && return
    [ -d "$HOME/repos/$query" ] && echo "$HOME/repos/$query" && return

    local match
    match=$(find "$HOME" -maxdepth 2 -type d -iname "*${query}*" \
        ! -path '*/.*' ! -path "$HOME" 2>/dev/null | head -1)

    if [ -n "$match" ]; then
        echo "$match"
    else
        # Default landing dir: $HOME/repos if it exists, else $HOME
        [ -d "$HOME/repos" ] && echo "$HOME/repos" || echo "$HOME"
    fi
}

# Source client profile + run a command in a pane
_pane_init() {
    local target="$1"
    shift
    tmux send-keys -t "$target" "source $CLIENTRC 2>/dev/null; clear" Enter
    if [ $# -gt 0 ]; then
        sleep 0.2
        tmux send-keys -t "$target" "$*" Enter
    fi
}

# Determine working directory and session name
if [ -n "$PROJECT" ]; then
    WORK_DIR=$(resolve_project_dir "$PROJECT")
    SESSION="$PROJECT"
else
    # Default landing: $HOME/repos if it exists, else $HOME
    [ -d "$HOME/repos" ] && WORK_DIR="$HOME/repos" || WORK_DIR="$HOME"
    SESSION="workspace"
fi

[ ! -d "$WORK_DIR" ] && WORK_DIR="$HOME"

# If session already exists, just attach
if tmux has-session -t "=$SESSION" 2>/dev/null; then
    tmux attach -t "=$SESSION"
    exit 0
fi

# Window 1: workspace (3 panes)
tmux new-session -d -s "$SESSION" -c "$WORK_DIR" -n "workspace"
sleep 0.3

tmux split-window -h -t "$SESSION:workspace" -c "$WORK_DIR" -l 35%
tmux split-window -v -t "$SESSION:workspace.1" -c "$WORK_DIR" -l 40%

# Init all panes
_pane_init "$SESSION:workspace.0" "ls -la"
_pane_init "$SESSION:workspace.1" "git log --oneline --graph -15 2>/dev/null || ls"
_pane_init "$SESSION:workspace.2" "git status 2>/dev/null || echo 'No git repo'"

tmux select-pane -t "$SESSION:workspace.0"

# Window 2: docker
tmux new-window -t "$SESSION" -n "docker" -c "$WORK_DIR"
_pane_init "$SESSION:docker" "docker ps 2>/dev/null || echo 'No containers running'"

# Window 3: htop
tmux new-window -t "$SESSION" -n "htop" -c "$WORK_DIR"
tmux send-keys -t "$SESSION:htop" "htop" Enter

# Go back to workspace window
tmux select-window -t "$SESSION:workspace"

# Attach
tmux attach -t "$SESSION"
