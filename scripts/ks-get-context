#!/bin/bash

# ks-get-context: Display the current keychain context
# Usage: ks-get-context

KS_CONFIG_DIR="${HOME}/.config/ks"
KS_CONTEXT_FILE="${KS_CONFIG_DIR}/current-context"

if [ -f "${KS_CONTEXT_FILE}" ]; then
    CONTEXT=$(cat "${KS_CONTEXT_FILE}")
    echo "Current context: ${CONTEXT}"

    # Check if KS_DEFAULT_KEYCHAIN env var is set
    if [ -n "${KS_DEFAULT_KEYCHAIN}" ]; then
        if [ "${KS_DEFAULT_KEYCHAIN}" = "${CONTEXT}" ]; then
            echo "Environment variable: ✓ matches (${KS_DEFAULT_KEYCHAIN})"
        else
            echo "Environment variable: ⚠ mismatch (${KS_DEFAULT_KEYCHAIN})"
            echo "Run: export KS_DEFAULT_KEYCHAIN=${CONTEXT}"
        fi
    else
        echo "Environment variable: ✗ not set"
        echo "Run: export KS_DEFAULT_KEYCHAIN=${CONTEXT}"
    fi
else
    echo "No context set"
    echo "Use: ks-set-context <context-name>"
fi
