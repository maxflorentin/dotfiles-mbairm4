#!/bin/bash

# ks-add: Add a secret to the current context
# Usage: ks-add [options] <key> [value]
# Options:
#   -f <file>    Read value from file

# Check if ks is installed
if ! command -v ks &> /dev/null; then
    echo "Error: ks is not installed"
    echo "Install with: brew install ks"
    exit 1
fi

# Parse arguments
KEY=""
VALUE=""
FILE_PATH=""
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f)
            FILE_PATH="$2"
            shift 2
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

if [ -n "$FILE_PATH" ]; then
    if [ ${#ARGS[@]} -lt 1 ]; then
        echo "Error: Key name required"
        echo "Usage: ks-add -f <file> <key>"
        exit 1
    fi
    KEY="${ARGS[0]}"
    if [ ! -f "$FILE_PATH" ]; then
        echo "Error: File not found: $FILE_PATH"
        exit 1
    fi
    VALUE=$(cat "$FILE_PATH")
else
    if [ ${#ARGS[@]} -lt 1 ]; then
        echo "Error: Key name required"
        echo "Usage: ks-add <key> [value]"
        exit 1
    fi
    KEY="${ARGS[0]}"
    VALUE="${ARGS[1]}"
fi

# Get current context
KS_CONFIG_DIR="${HOME}/.config/ks"
KS_CONTEXT_FILE="${KS_CONFIG_DIR}/current-context"

# Determine which keychain to use
if [ -n "${KS_DEFAULT_KEYCHAIN}" ]; then
    CONTEXT="${KS_DEFAULT_KEYCHAIN}"
elif [ -f "${KS_CONTEXT_FILE}" ]; then
    CONTEXT=$(cat "${KS_CONTEXT_FILE}")
else
    echo "Error: No context set"
    echo "Run: ks-set-context <context-name>"
    exit 1
fi

echo "Adding secret to context: ${CONTEXT}"

# Function to add the secret
add_secret() {
    if [ -z "$VALUE" ]; then
        ks -k "${CONTEXT}" add "${KEY}"
    else
        ks -k "${CONTEXT}" add "${KEY}" "${VALUE}"
    fi
}

# Try to add the secret
OUTPUT=$(add_secret 2>&1)
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    echo "✓ Secret '${KEY}' added to '${CONTEXT}'"
else
    if [[ "$OUTPUT" == *"already exists"* ]]; then
        echo "! Secret '${KEY}' already exists."
        read -p "Do you want to overwrite it? (y/N): " CONFIRM
        if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
            echo "Overwriting..."
            ks -k "${CONTEXT}" rm "${KEY}" > /dev/null 2>&1
            add_secret > /dev/null 2>&1
            if [ $? -eq 0 ]; then
                echo "✓ Secret '${KEY}' updated in '${CONTEXT}'"
                exit 0
            else
                echo "✗ Failed to update secret"
                exit 1
            fi
        else
            echo "Aborted."
            exit 0
        fi
    fi
    echo "✗ Failed to add secret: $OUTPUT"
    exit 1
fi
