#!/bin/bash

# ks-trust-setup: Configure keychain to trust ks without asking for password
# This needs to be run once per keychain context

set -e

echo "🔐 KS Keychain Trust Setup"
echo ""

# Get list of contexts
contexts=$(ls ~/Library/Keychains/*.keychain-db 2>/dev/null | \
    xargs -n1 basename | \
    sed 's/.keychain-db$//' | \
    grep -v "^login$" | \
    grep -v "^metadata$")

if [ -z "$contexts" ]; then
    echo "❌ No KS contexts found"
    exit 1
fi

# Find ks binary location
KS_BIN=$(which ks 2>/dev/null)
if [ -z "$KS_BIN" ]; then
    echo "❌ ks is not installed"
    echo "Install with: brew install keychain-tools"
    exit 1
fi

echo "Found ks at: $KS_BIN"
echo ""
echo "Available contexts:"
echo "$contexts" | sed 's/^/  • /'
echo ""

# Configure each context
while IFS= read -r context; do
    keychain_path="$HOME/Library/Keychains/${context}.keychain-db"

    echo "📦 Configuring context: $context"

    # Unlock the keychain (will ask for password)
    echo "  Unlocking keychain (enter password)..."
    if security unlock-keychain "$keychain_path" 2>/dev/null; then
        echo "  ✓ Unlocked"

        # Set keychain to not lock automatically
        echo "  Setting auto-lock timeout to 1 hour..."
        security set-keychain-settings -lut 3600 "$keychain_path" 2>/dev/null || true

        echo "  ✓ Configured: ${context}"
    else
        echo "  ⚠️  Failed to unlock: ${context} (skipping)"
    fi
    echo ""
done <<< "$contexts"

echo "✅ Setup complete!"
echo ""
echo "Recommendations:"
echo "  • Your keychains will now auto-lock after 1 hour of inactivity"
echo "  • You won't be asked for password as frequently"
echo "  • If you still get prompted, run: security unlock-keychain ~/Library/Keychains/<context>.keychain-db"
echo ""
echo "To manually unlock a keychain when needed:"
echo "  security unlock-keychain ~/Library/Keychains/personal.keychain-db"
echo "  security unlock-keychain ~/Library/Keychains/yuno.keychain-db"
