#!/bin/bash
# work-tracker: Log and report client work time
# Usage:
#   work-tracker start <client> [project] [source]
#   work-tracker stop  <client> [project] [source]
#   work-tracker pulse                              # cron: log active tmux sessions
#   work-tracker status
#   work-tracker report [--day|--week|--month|--all]

set -e

PULSE_INTERVAL=300  # 5 minutes — must match cron schedule
IDLE_THRESHOLD=300  # seconds since last tmux input to consider idle

LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/work-tracker"
LOG_FILE="$LOG_DIR/log.tsv"

mkdir -p "$LOG_DIR"
[ -f "$LOG_FILE" ] || printf 'timestamp\tevent\tclient\tproject\tsource\n' > "$LOG_FILE"

_log_event() {
    printf '%s\t%s\t%s\t%s\t%s\n' "$(date +%s)" "$1" "$2" "$3" "$4" >> "$LOG_FILE"
}

_last_event() {
    awk -F'\t' -v c="$1" -v p="$2" '$3==c && $4==p {e=$2} END{print e}' "$LOG_FILE"
}

cmd_start() {
    local client="$1" project="${2:-}" source="${3:-$(hostname -s)}"
    [ -z "$client" ] && { echo "Usage: work-tracker start <client> [project] [source]"; exit 1; }
    [ "$(_last_event "$client" "$project")" = "start" ] && return 0
    _log_event "start" "$client" "$project" "$source"
}

cmd_stop() {
    local client="$1" project="${2:-}" source="${3:-$(hostname -s)}"
    [ -z "$client" ] && { echo "Usage: work-tracker stop <client> [project] [source]"; exit 1; }
    [ "$(_last_event "$client" "$project")" != "start" ] && return 0
    _log_event "stop" "$client" "$project" "$source"
}

# pulse: called by cron every 5 min on Pi (per client user)
# Client is derived from $USER. Session name becomes the project.
cmd_pulse() {
    command -v tmux >/dev/null 2>&1 || return 0
    local now
    now=$(date +%s)
    local client="${USER:-$(whoami)}"

    tmux list-sessions -F '#{session_name} #{session_activity}' 2>/dev/null | while read -r session last_activity; do
        # Skip generic sessions
        [ "$session" = "main" ] && continue

        # In per-user mode, the "workspace" session is project-less
        local project="$session"
        [ "$session" = "workspace" ] && project=""

        local idle=$((now - last_activity))
        if [ "$idle" -lt "$IDLE_THRESHOLD" ]; then
            _log_event "tick" "$client" "$project" "pi"
        fi
    done
}

cmd_status() {
    # Show sessions with recent ticks (last 10 min) or open start events
    local now
    now=$(date +%s)
    local cutoff=$((now - 600))

    awk -F'\t' -v now="$now" -v cutoff="$cutoff" '
    NR==1 { next }
    {
        key = $3 ($4 ? "/"$4 : "")
        # Track start/stop state
        if ($2 == "start") { active[key] = $1; src[key] = $5 }
        if ($2 == "stop") { delete active[key] }
        # Track recent ticks
        if ($2 == "tick" && $1 >= cutoff) { ticked[key] = $1; tsrc[key] = $5 }
    }
    END {
        found = 0
        # Show ticked sessions (real activity)
        for (k in ticked) {
            elapsed = now - ticked[k]
            m = int(elapsed / 60)
            printf "%s (%s) — active %dm ago\n", k, tsrc[k], m
            found = 1
        }
        # Show connected but idle sessions
        for (k in active) {
            if (!(k in ticked)) {
                elapsed = now - active[k]
                h = int(elapsed / 3600)
                m = int((elapsed % 3600) / 60)
                printf "%s (%s) — connected %dh%02dm (idle)\n", k, src[k], h, m
                found = 1
            }
        }
        if (!found) print "No active sessions"
    }' "$LOG_FILE"
}

cmd_report() {
    local period="${1:---week}"
    local now
    now=$(date +%s)
    local cutoff=0

    case "$period" in
        --day)   cutoff=$((now - 86400)) ;;
        --week)  cutoff=$((now - 604800)) ;;
        --month) cutoff=$((now - 2592000)) ;;
        --cal)   cutoff=$(date -d "$(date +%Y-%m-01)" +%s 2>/dev/null || date -j -f "%Y-%m-%d" "$(date +%Y-%m)-01" +%s) ;;
        --prev)  cutoff=$(date -d "$(date -d '1 month ago' +%Y-%m-01)" +%s 2>/dev/null || date -j -v-1m -f "%Y-%m-%d" "$(date +%Y-%m)-01" +%s)
                 now=$(date -d "$(date +%Y-%m-01)" +%s 2>/dev/null || date -j -f "%Y-%m-%d" "$(date +%Y-%m)-01" +%s) ;;
        --all)   cutoff=0 ;;
        *) echo "Usage: work-tracker report [--day|--week|--month|--cal|--prev|--all]"; exit 1 ;;
    esac

    local file="${WORK_TRACKER_LOG:-$LOG_FILE}"

    awk -F'\t' -v cutoff="$cutoff" -v now="$now" -v interval="$PULSE_INTERVAL" '
    NR==1 { next }
    $1 < cutoff { next }
    {
        key = $3 ($4 ? "/"$4 : "")
        if ($2 == "tick") {
            # Each tick = PULSE_INTERVAL seconds of active work
            ticks[key]++
        } else if ($2 == "start") {
            starts[key] = $1
        } else if ($2 == "stop" && starts[key]) {
            connected[key] += $1 - starts[key]
            delete starts[key]
        }
    }
    END {
        # Count still-open connections
        for (k in starts) connected[k] += now - starts[k]

        printf "%-24s %8s %10s\n", "CLIENT", "ACTIVE", "CONNECTED"
        printf "%-24s %8s %10s\n", "------------------------", "--------", "----------"
        grand_active = 0
        grand_conn = 0
        n = 0
        for (k in ticks) {
            active_h = (ticks[k] * interval) / 3600
            conn_h = (k in connected) ? connected[k] / 3600 : 0
            grand_active += active_h
            grand_conn += conn_h
            lines[n++] = sprintf("%-24s %7.1fh %9.1fh", k, active_h, conn_h)
            # Remove from connected so we can print connect-only clients after
            delete connected[k]
        }
        # Clients with connection time but no ticks (Mac-only, no Pi pulse)
        for (k in connected) {
            conn_h = connected[k] / 3600
            grand_conn += conn_h
            lines[n++] = sprintf("%-24s %8s %9.1fh", k, "-", conn_h)
        }
        for (i = 0; i < n; i++) print lines[i]
        printf "%-24s %8s %10s\n", "------------------------", "--------", "----------"
        printf "%-24s %7.1fh %9.1fh\n", "TOTAL", grand_active, grand_conn
    }' "$file"
}

cmd_monthly_save() {
    local report_dir="$LOG_DIR/reports"
    local prev_month
    prev_month=$(date -d '1 month ago' +%Y-%m 2>/dev/null || date -j -v-1m +%Y-%m)
    local report_file="$report_dir/$prev_month.txt"

    mkdir -p "$report_dir"
    if [ -f "$report_file" ]; then
        echo "Report already exists: $report_file"
        return 0
    fi

    {
        echo "=== Work Report: $prev_month ==="
        echo ""
        cmd_report --prev
    } > "$report_file"
    echo "Saved: $report_file"
}

case "${1:-}" in
    start)        shift; cmd_start "$@" ;;
    stop)         shift; cmd_stop "$@" ;;
    pulse)        cmd_pulse ;;
    status)       cmd_status ;;
    report)       shift; cmd_report "$@" ;;
    monthly-save) cmd_monthly_save ;;
    *)            echo "work-tracker: start|stop|pulse|status|report|monthly-save" ;;
esac
