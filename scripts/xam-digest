#!/bin/bash
# xam-digest: Run Xam Slack digest in a new terminal tab
# Usage: xam-digest [am|noon|pm]
# Scheduled via cron: 0 9,12,16 * * 1-5 ~/Scripts/dotfiles/xam-digest

set -euo pipefail

PERIOD="${1:-}"
HOUR=$(date +%H)

if [ -z "$PERIOD" ]; then
  if [ "$HOUR" -lt 11 ]; then
    PERIOD="am"
  elif [ "$HOUR" -lt 14 ]; then
    PERIOD="noon"
  else
    PERIOD="pm"
  fi
fi

TAG="#digest-${PERIOD}"
DATE=$(date +%Y-%m-%d)
PROMPT="Session tag: ${TAG}. Run Slack digest for ${DATE}. Read modules/slack-digest.md and slack-channels.md, then read priority Slack channels, search secondary channels for KR keywords, generate digest in memory/daily-log-${DATE}.md, and create action items in memory/todos-tracking.md. Be concise."

# Open new iTerm2 tab and run claude with xam skill
osascript -e "
tell application \"iTerm2\"
  activate
  tell current window
    create tab with default profile
    tell current session
      write text \"cd $HOME/Projects/dotfiles && claude -p '/xam ${PROMPT}'\"
    end tell
  end tell
end tell
"
