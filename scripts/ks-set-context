#!/bin/bash

# ks-set-context: Set the active keychain context for ks
# Usage: ks-set-context <context-name>
# Example: ks-set-context j1

if [ -z "$1" ]; then
    echo "Error: Context name required"
    echo "Usage: ks-set-context <context-name>"
    echo "Examples: j1, j2, j3, personal"
    exit 1
fi

CONTEXT="$1"
KS_CONFIG_DIR="${HOME}/.config/ks"
KS_CONTEXT_FILE="${KS_CONFIG_DIR}/current-context"

# Create config directory if it doesn't exist
mkdir -p "${KS_CONFIG_DIR}"

# Save the context
echo "${CONTEXT}" > "${KS_CONTEXT_FILE}"

# Export for current shell session
export KS_DEFAULT_KEYCHAIN="${CONTEXT}"

echo "✓ Context set to: ${CONTEXT}"
echo ""
echo "To make this permanent in your current shell, run:"
echo "  export KS_DEFAULT_KEYCHAIN=${CONTEXT}"
echo ""
echo "Or add this to your ~/.zshrc:"
echo "  export KS_DEFAULT_KEYCHAIN=\$(cat ${KS_CONTEXT_FILE} 2>/dev/null || echo 'personal')"
