#!/bin/bash

# ks-cp: Copy a secret to clipboard (with fzf selection)
# Usage: ks-cp [key]
# If no key is provided, uses fzf to select from available secrets

# Check if ks is installed
if ! command -v ks &> /dev/null; then
    echo "Error: ks is not installed" >&2
    echo "Install with: brew install ks" >&2
    exit 1
fi

# Get current context
KS_CONFIG_DIR="${HOME}/.config/ks"
KS_CONTEXT_FILE="${KS_CONFIG_DIR}/current-context"

# Determine which keychain to use
if [ -n "${KS_DEFAULT_KEYCHAIN}" ]; then
    CONTEXT="${KS_DEFAULT_KEYCHAIN}"
elif [ -f "${KS_CONTEXT_FILE}" ]; then
    CONTEXT=$(cat "${KS_CONTEXT_FILE}")
else
    echo "Error: No context set" >&2
    echo "Run: ks-set-context <context-name>" >&2
    exit 1
fi

# If key is provided as argument, use it; otherwise use fzf
if [ -n "$1" ]; then
    KEY="$1"
else
    # Check if fzf is installed
    if ! command -v fzf &> /dev/null; then
        echo "Error: fzf is not installed" >&2
        echo "Install with: brew install fzf" >&2
        exit 1
    fi

    # Get list of secrets and select with fzf
    KEY=$(ks -k "${CONTEXT}" ls 2>/dev/null | fzf --prompt="Select secret to copy: " --height=40% --reverse)

    # Exit if no selection made
    if [ -z "$KEY" ]; then
        echo "No secret selected" >&2
        exit 1
    fi
fi

# Get the secret value
VALUE=$(ks -k "${CONTEXT}" show "${KEY}" 2>/dev/null)

if [ -z "$VALUE" ]; then
    echo "Error: Could not retrieve secret '${KEY}'" >&2
    exit 1
fi

# Copy to clipboard
echo -n "$VALUE" | pbcopy

echo "✓ Copied '${KEY}' to clipboard (context: ${CONTEXT})"
