#!/bin/bash

# envy-clear: Remove ALL secrets from a context (dangerous!)
# Usage: envy-clear <context>

set -e

ENVY_DIR="${HOME}/.envy"
ENVY_KEYS_DIR="${ENVY_DIR}/keys"

if [ -z "$1" ]; then
    echo "Usage: envy-clear <context>"
    echo ""
    echo "⚠️  WARNING: This will delete ALL secrets in the context!"
    echo ""
    echo "Example:"
    echo "  envy-clear work"
    exit 1
fi

CONTEXT="$1"
KEY_FILE="${ENVY_KEYS_DIR}/${CONTEXT}.key"
ENVY_FILE="${ENVY_DIR}/${CONTEXT}.envy.age"

# Verify context exists
if [ ! -f "${KEY_FILE}" ]; then
    echo "❌ Context '${CONTEXT}' not found"
    exit 1
fi

if [ ! -f "${ENVY_FILE}" ]; then
    echo "✓ Context '${CONTEXT}' is already empty"
    exit 0
fi

# Show what will be deleted
echo "⚠️  This will delete ALL secrets from context: ${CONTEXT}"
echo ""
echo "Secrets that will be deleted:"
age -d -i "${KEY_FILE}" "${ENVY_FILE}" 2>/dev/null | grep -v '^#' | grep '=' | while IFS='=' read -r key value; do
    echo "  • ${key}"
done
echo ""

read -p "Are you sure? Type 'yes' to confirm: " CONFIRM

if [ "$CONFIRM" != "yes" ]; then
    echo "Aborted."
    exit 0
fi

# Remove the encrypted file
rm -f "${ENVY_FILE}"

echo ""
echo "✓ Cleared all secrets from context '${CONTEXT}'"
echo ""
echo "The context still exists. Add new secrets with: envy-set"
