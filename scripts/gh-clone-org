#!/bin/bash

# gh-clone-org: Clone all repos from a GitHub org/user
# Usage: gh-clone-org <org> [destination] [--ssh-host alias]
#   gh-clone-org MuttData .
#   gh-clone-org MuttData . --ssh-host github.com-mutt

set -e

ORG=""
DEST="."
SSH_HOST=""
FILTER=""

# Parse arguments
while [ $# -gt 0 ]; do
    case "$1" in
        --ssh-host) SSH_HOST="$2"; shift 2 ;;
        --filter)   FILTER="$2"; shift 2 ;;
        *) [ -z "$ORG" ] && ORG="$1" || DEST="$1"; shift ;;
    esac
done

if [ -z "$ORG" ]; then
    echo "Usage: gh-clone-org <org> [destination] [options]"
    echo ""
    echo "Options:"
    echo "  --filter <pattern>  Filter repos by name (grep regex)"
    echo "  --ssh-host <alias>  Use SSH host alias from ~/.ssh/config"
    echo ""
    echo "Examples:"
    echo "  gh-clone-org MuttData ."
    echo "  gh-clone-org MuttData . --filter mixilo"
    echo "  gh-clone-org MuttData . --filter 'spark|airflow' --ssh-host github.com-mutt"
    exit 1
fi

# Extract org name from URL if needed
ORG="${ORG##*/}"
ORG="${ORG%.git}"

# Check gh auth
if ! gh auth status &>/dev/null; then
    echo "Not authenticated. Run: gh auth login"
    exit 1
fi

mkdir -p "$DEST"

echo "Fetching repos for $ORG${FILTER:+ (filter: $FILTER)}..."
repos=$(gh repo list "$ORG" --limit 1000 --json name,sshUrl,isArchived --jq '.[] | select(.isArchived == false) | .name + " " + .sshUrl')

# Apply filter if provided
if [ -n "$FILTER" ]; then
    repos=$(echo "$repos" | grep -iE "$FILTER" || true)
fi

if [ -z "$repos" ]; then
    echo "No repos found (or no access). Try: gh auth login"
    exit 1
fi

total=$(echo "$repos" | wc -l | tr -d ' ')
count=0

echo "$repos" | while read -r name url; do
    count=$((count + 1))

    # Replace github.com with SSH host alias if provided
    if [ -n "$SSH_HOST" ]; then
        url=$(echo "$url" | sed "s|git@github.com:|git@${SSH_HOST}:|")
    fi

    if [ -d "$DEST/$name" ]; then
        echo "[$count/$total] $name (exists, pulling)"
        git -C "$DEST/$name" pull --ff-only 2>/dev/null || true
    else
        echo "[$count/$total] $name (cloning)"
        git clone "$url" "$DEST/$name" 2>/dev/null || echo "  (failed, skipping)"
    fi
done

echo ""
echo "Done. $total repos in $DEST/"
