#!/bin/bash

# install: Set up dotfiles symlinks and config
# Idempotent - safe to run multiple times
# Detects macOS vs Linux and applies platform-specific config

set -e

DOTFILES="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"
ARCH="$(uname -m)"

echo "dotfiles install ($OS/$ARCH)"
echo "  from: $DOTFILES"
echo ""

# === Common (all platforms) ===

# Shell
ln -sfn "$DOTFILES/shell/zshrc" "$HOME/.zshrc"

# Git
ln -sfn "$DOTFILES/.gitignore_global" "$HOME/.gitignore_global"
git config --global core.excludesfile "$HOME/.gitignore_global"

# Neovim
mkdir -p "$HOME/.config"
ln -sfn "$DOTFILES/editors/nvim" "$HOME/.config/nvim"

# Scripts → ~/.local/bin
mkdir -p "$HOME/.local/bin"

# Envy scripts
if [ -d "$DOTFILES/scripts/envy" ]; then
    for s in "$DOTFILES/scripts/envy"/envy-*; do
        [ -f "$s" ] && ln -sf "$s" "$HOME/.local/bin/$(basename "$s")"
    done
fi

# Standalone scripts
for s in gh-clone-org brew-sync uv-setup xam-digest sqlit-add-connection work-tracker; do
    [ -f "$DOTFILES/scripts/$s" ] && ln -sf "$DOTFILES/scripts/$s" "$HOME/.local/bin/$s"
done

echo "  common: shell, nvim, scripts"

# === macOS ===
if [ "$OS" = "Darwin" ]; then
    # VS Code settings
    VSCODE_DIR="$HOME/Library/Application Support/Code/User"
    if [ -d "$VSCODE_DIR" ]; then
        ln -sf "$DOTFILES/editors/vscode/settings.json" "$VSCODE_DIR/settings.json"
        echo "  macos: vscode"
    fi

    # Mackup
    ln -sf "$DOTFILES/macos/mackup.cfg" "$HOME/.mackup.cfg"

    # work CLI (manage Pi from Mac)
    ln -sf "$DOTFILES/linux/work" "$HOME/.local/bin/work"

    echo "  macos: mackup, work cli"
    echo ""
    echo "Fresh Mac? Run: $DOTFILES/macos/fresh.sh"
fi

# === Linux ===
if [ "$OS" = "Linux" ]; then
    # tmux
    ln -sfn "$DOTFILES/linux/tmux.conf" "$HOME/.tmux.conf"

    # tmux-layout + work CLI
    ln -sf "$DOTFILES/linux/tmux-layout" "$HOME/.local/bin/tmux-layout"
    ln -sf "$DOTFILES/linux/work" "$HOME/.local/bin/work"

    # work-tracker pulse cron (every 5 min, logs active tmux sessions)
    if ! crontab -l 2>/dev/null | grep -qF "work-tracker pulse"; then
        (crontab -l 2>/dev/null; echo "*/5 * * * * $HOME/.local/bin/work-tracker pulse >/dev/null 2>&1") | crontab -
    fi
    if ! crontab -l 2>/dev/null | grep -qF "work-tracker monthly-save"; then
        (crontab -l 2>/dev/null; echo "0 1 1 * * $HOME/.local/bin/work-tracker monthly-save >/dev/null 2>&1") | crontab -
    fi
    echo "  linux: tmux, tmux-layout, work cli, time-tracker crons"

    # Ensure SSH config.d Include (recovers client SSH configs after re-clone)
    mkdir -p "$HOME/.ssh/config.d" && chmod 700 "$HOME/.ssh" "$HOME/.ssh/config.d" 2>/dev/null
    if [ -f "$HOME/.ssh/config" ]; then
        if ! grep -q 'Include config.d/\*' "$HOME/.ssh/config" 2>/dev/null; then
            { echo 'Include config.d/*'; cat "$HOME/.ssh/config"; } > "$HOME/.ssh/config.tmp"
            mv "$HOME/.ssh/config.tmp" "$HOME/.ssh/config"
            chmod 600 "$HOME/.ssh/config"
            echo "  linux: ssh config.d Include (added)"
        fi
    else
        echo 'Include config.d/*' > "$HOME/.ssh/config"
        chmod 600 "$HOME/.ssh/config"
        echo "  linux: ssh config.d Include (created)"
    fi

    # Ensure sshd is running and enabled (critical for remote access)
    if command -v systemctl &>/dev/null; then
        if ! systemctl is-active --quiet sshd 2>/dev/null && ! systemctl is-active --quiet ssh 2>/dev/null; then
            echo "  WARNING: sshd is not running! Starting..."
            sudo systemctl start sshd 2>/dev/null || sudo systemctl start ssh 2>/dev/null || true
        fi
        systemctl is-enabled --quiet sshd 2>/dev/null || systemctl is-enabled --quiet ssh 2>/dev/null || {
            echo "  WARNING: sshd not enabled at boot! Enabling..."
            sudo systemctl enable sshd 2>/dev/null || sudo systemctl enable ssh 2>/dev/null || true
        }
    fi

    if [ "$ARCH" = "aarch64" ]; then
        echo ""
        echo "Pi detected. Fresh setup? Run: $DOTFILES/linux/bootstrap.sh"
    fi
fi

echo ""
echo "Done. Reload: exec zsh"
