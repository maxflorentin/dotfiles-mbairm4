# Environment variables for dotfiles configuration
# Copy this file to .env and customize for your machine

# Machine name (used in macos/defaults.sh for computer name)
MACHINE_NAME=my-mac

# Homebrew prefix (usually /opt/homebrew on Apple Silicon, /usr/local on Intel)
HOMEBREW_PREFIX=/opt/homebrew

# PhpStorm application path
PHPSTORM_APP=/Applications/PhpStorm.app

# MSSQL password for Docker alias
# MSSQL_PASSWORD=changeme

# Node bin path
NODE_BIN=$HOME/.node/bin

# Zsh syntax highlighting path
ZSH_SYNTAX_HIGHLIGHTING=$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Docker host socket (for podman on macOS)
# DOCKER_HOST="unix:///path/to/podman.sock"

# Pi workstation hostname (for work CLI)
# WORK_PI_HOST=pi-workstation
# WORK_PI_USER=max
